rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ══════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'admin@gmail.com';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ══════════════════════════════════════════
    //  PRODUCTS
    // ══════════════════════════════════════════
    match /products/{productId} {
      allow read: if true;
      // FIX: allow update for authenticated users so stock can be decremented during purchase
      allow update: if isAuthenticated(); 
      allow create, delete: if isAdmin();
    }

    // ══════════════════════════════════════════
    //  CATEGORIES
    // ══════════════════════════════════════════
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════
    //  PROMOTIONS / BANNERS
    // ══════════════════════════════════════════
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════
    //  SUPPORT MESSAGES
    // ══════════════════════════════════════════
    match /support_messages/{messageId} {
      allow create: if true;
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ══════════════════════════════════════════
    //  ORDERS
    // ══════════════════════════════════════════
    match /orders/{orderId} {
      allow create: if isAuthenticated();
      allow read:   if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ══════════════════════════════════════════
    //  USERS
    // ══════════════════════════════════════════
    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read:   if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /wishlist/{itemId}         { allow read, write: if isOwner(userId); }
      match /budget/{docId}            { allow read, write: if isOwner(userId); }
      match /transactions/{txId}       { allow read, write: if isOwner(userId); }
      match /recently_scanned/{itemId} { allow read, write: if isOwner(userId); }
      match /userAddresses/{addressId} { allow read, write: if isOwner(userId); }
      match /settings/{docId}          { allow read, write: if isOwner(userId); }
    }
  }
}
